# Canonical central / hosting app URL for all envs (edge Pis sync from here).
APP_NAME="FlexiQueue"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://flexiqueue.click

# When true, login page shows a "Demo accounts" section (seeded emails + password hint).
# DEMO=false

LOG_CHANNEL=stack
LOG_LEVEL=info

# MySQL (hosting)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

CACHE_STORE=file
QUEUE_CONNECTION=database
SESSION_DRIVER=database

# Pusher (hosting). Create app at pusher.com, get credentials from dashboard.
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

VITE_BROADCASTER=pusher
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Vite build-time (other defaults)
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=
VITE_REVERB_VIA_PROXY=

# Reverb (unused when Pusher)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Mail, TTS (same as .env.prod)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
TTS_DRIVER=elevenlabs
TTS_DEFAULT_VOICE_ID=ofwR5KwL2nT4XZAub5qx
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Password used by php-run-scripts/run.php on hosting
RUN_SCRIPTS_PASSWORD=123456
