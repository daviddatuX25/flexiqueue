<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1) Block sensitive files and directories from direct web access
    RewriteRule ^(\.env|\.env\..*|composer\.(json|lock)|artisan)$ - [F,L]
    RewriteRule ^(vendor|storage|bootstrap|config|database|resources|routes|tests|node_modules|secure)/ - [F,L]

    # 2) Allow php-run-scripts/* to run directly (for deploy/initial scripts)
    RewriteRule ^php-run-scripts/ - [L]

    # 3) Anything already under /public just continues normally
    RewriteCond %{REQUEST_URI} ^/public/
    RewriteRule ^ - [L]

    # 4) Root URL (/) → Laravel front controller (no index.html needed)
    RewriteRule ^$ public/index.php [L]

    # 5) For everything else, route into public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
