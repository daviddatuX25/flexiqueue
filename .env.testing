# Test environment — loaded when APP_ENV=testing (e.g. phpunit).
# Uses SQLite in-memory by default so RefreshDatabase gets a fresh DB with no shared state.
# For MariaDB integration tests, set DB_CONNECTION=mariadb and create the DB:
#   sail mysql -e "CREATE DATABASE IF NOT EXISTS testing;"

APP_NAME=FlexiQueue
APP_ENV=testing
APP_KEY=base64:LLykhOfbrxstY0pgX6RdnL2CpOQ5uh5XAb4Yn7Mv0Hk=
APP_DEBUG=true
APP_URL=http://localhost

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=null
MAIL_MAILER=array

FILESYSTEM_DISK=local
