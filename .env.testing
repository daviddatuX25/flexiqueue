# Test environment — loaded when APP_ENV=testing (e.g. phpunit).
# Uses a separate DB so RefreshDatabase does not touch your dev data.
# Create the DB once: e.g. sail mysql -e "CREATE DATABASE IF NOT EXISTS testing;"

APP_NAME=FlexiQueue
APP_ENV=testing
APP_KEY=base64:LLykhOfbrxstY0pgX6RdnL2CpOQ5uh5XAb4Yn7Mv0Hk=
APP_DEBUG=true
APP_URL=http://localhost

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=testing
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=null
MAIL_MAILER=array

FILESYSTEM_DISK=local
