# Central profile (Reverb realtime)
# Copy to .env as needed for central deployments using Reverb.

APP_NAME=FlexiQueue
APP_ENV=production
APP_MODE=central
APP_KEY=
APP_DEBUG=false
APP_URL=https://flexiqueue.click

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=flexiqueue
REVERB_APP_KEY=flexiqueue-prod-key
REVERB_APP_SECRET=flexiqueue-prod-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=6001
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
