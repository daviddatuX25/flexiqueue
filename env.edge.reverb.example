# Edge profile (Reverb realtime, canonical edge default).
# Copy to .env.edge and fill central sync values.

APP_NAME=FlexiQueue
APP_ENV=production
APP_MODE=edge
APP_KEY=
APP_DEBUG=false
APP_URL=http://flexiqueue.edge

CENTRAL_URL=https://flexiqueue.click
CENTRAL_API_KEY=
SITE_ID=
EDGE_PROGRAM_ID=

DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=flexiqueue
REVERB_APP_KEY=flexiqueue-prod-key
REVERB_APP_SECRET=flexiqueue-prod-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=6001
REVERB_SCHEME=http
