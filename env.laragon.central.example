# Laragon central environment template
# Copy to .env on the Laragon central target.

APP_NAME=FlexiQueue
APP_ENV=production
APP_MODE=central
APP_KEY=
APP_DEBUG=false
APP_URL=http://flexiqueue.local

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=flexiqueue
DB_USERNAME=root
DB_PASSWORD=

QUEUE_CONNECTION=database
CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=flexiqueue
REVERB_APP_KEY=flexiqueue-prod-key
REVERB_APP_SECRET=flexiqueue-prod-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=6001
REVERB_SCHEME=http
