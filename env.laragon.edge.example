# Laragon edge environment template
# Copy to .env on the Laragon edge target.

APP_NAME=FlexiQueue
APP_ENV=production
APP_MODE=edge
APP_KEY=
APP_DEBUG=false
APP_URL=http://flexiqueue.edge

# Edge runs local/offline against sqlite.
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite
QUEUE_CONNECTION=database

# Central connection for sync/import.
CENTRAL_URL=https://flexiqueue.click
CENTRAL_API_KEY=
SITE_ID=
EDGE_PROGRAM_ID=

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=flexiqueue
REVERB_APP_KEY=flexiqueue-prod-key
REVERB_APP_SECRET=flexiqueue-prod-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=6001
REVERB_SCHEME=http
# Laragon + Apache SSL: APP_URL=https://… and VITE_REVERB_VIA_PROXY=true; vhost proxies /app with ws:// → 127.0.0.1:6001 — see docs/SETUP-LARAGON-APACHE-REVERB-HTTPS.md

SYNC_BACK=false
EDGE_BRIDGE_MODE=false
