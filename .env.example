APP_NAME=FlexiQueue
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: Use 'mysql' for both MariaDB and MySQL
# Sail users: DB_HOST should be 'mariadb' (the Docker service name)
# Bare metal users: DB_HOST should be '127.0.0.1' or your MariaDB host
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=flexiqueue
DB_USERNAME=sail
DB_PASSWORD=password

# Per 05-SECURITY-CONTROLS: session driver = database
SESSION_DRIVER=database
# Minutes. Use 480 for 8-hour events (spec); 120 is fine for dev
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Dev: reverb for real-time. If Reverb isn't running we use "log" (no cURL error). To test real-time: add BROADCAST_FORCE_REVERB=1 and run: sail artisan reverb:start
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Laravel Reverb (WebSocket). Run reverb:start for real-time on dev. Prod/Pi get keys from .env.prod only (build + apply-tarball).
# Defaults here match .env.prod so a single prod build works; dev can use different keys in .env without affecting deploy.
REVERB_APP_ID=flexiqueue
REVERB_APP_KEY=flexiqueue-prod-key
REVERB_APP_SECRET=flexiqueue-prod-secret
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=6001
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
VITE_REVERB_VIA_PROXY=

# Server-side TTS (optional). When not set, display uses browser speechSynthesis.
TTS_DRIVER=elevenlabs
TTS_DEFAULT_VOICE_ID=ofwR5KwL2nT4XZAub5qx
ELEVENLABS_API_KEY=sk_388104f6e46394f707764a8388b8a48f8d76e4d2c104ac9e
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
