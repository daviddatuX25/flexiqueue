APP_NAME=FlexiQueue
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# When true, login page shows a "Demo accounts" section (seeded emails + password hint)
# DEMO=false
# DEMO=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: Use 'mysql' for both MariaDB and MySQL
# Sail users: DB_HOST should be 'mysql' (the Docker service name)
# Bare metal users: DB_HOST should be '127.0.0.1' or your MariaDB host
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=flexiqueue
DB_USERNAME=sail
DB_PASSWORD=password

# Per 05-SECURITY-CONTROLS: session driver = database
SESSION_DRIVER=database
# Minutes. Use 480 for 8-hour events (spec); 120 is fine for dev
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Dev: reverb for real-time. If Reverb isn't running we use "log" (no cURL error). To test real-time: add BROADCAST_FORCE_REVERB=1 and run: sail artisan reverb:start
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Mail testing (pick one) ---
# Default: log driver (no real SMTP; fine for php artisan test).
MAIL_MAILER=log
#
# Laragon / bare metal + Mailpit on Windows (UI http://localhost:8025/ — SMTP is usually port 1025):
# 1) Start Mailpit (your existing setup).
# 2) Uncomment and use the block below (or merge into your real .env).
# 3) Run: php artisan config:clear
# 4) Request "Forgot password" with a user that has recovery_gmail set; open Mailpit UI to read the message.
# MAIL_MAILER=smtp
# MAIL_HOST=127.0.0.1
# MAIL_PORT=1025
# MAIL_SCHEME=null
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
#
# Sail/Docker only: MAIL_HOST=mailpit (service name), same ports as above inside the network.
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Google OAuth (optional; leave GOOGLE_CLIENT_ID empty to hide "Sign in with Google") ---
# Production: APP_URL must be the canonical https://... origin (no trailing slash). Register the same callback in Google Cloud.
# Authorized redirect URI: {APP_URL}/auth/google/callback
# See docs/GOOGLE_OAUTH_AND_AGILA_HOSTING.md for Console setup + Agila/Hestia checklist.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# Staff triage full page: set false to redirect /triage to /station (footer QR is primary; device refactor Phase 1).
# FEATURE_STAFF_TRIAGE_PAGE=true

# Laragon (HTTP dev):
# APP_URL=http://flexiqueue.test
# VITE_ORIGIN=http://flexiqueue.test:5173
# VITE_HMR_HOST=flexiqueue.test
#
# Laragon + Apache SSL + Reverb (HTTPS — recommended pattern):
# 1) Menu → Apache → SSL → enable; site vhost :443 proxies /app with ws:// to 127.0.0.1:6001 (see docs/SETUP-LARAGON-APACHE-REVERB-HTTPS.md).
# 2) APP_URL=https://flexiqueue.test
# 3) VITE_REVERB_VIA_PROXY=true  (browser uses wss://flexiqueue.test/app/... not wss://localhost:6001)
# 4) Restart npm run dev after changing VITE_*.
# REVERB_SCHEME stays http for the Reverb process; TLS terminates at Apache.

# Laravel Reverb (WebSocket). Run reverb:start for real-time on dev. Prod/Pi get keys from .env.edge only (build + apply-tarball).
# Defaults here match .env.edge so a single prod build works; dev can use different keys in .env without affecting deploy.
REVERB_APP_ID=flexiqueue
REVERB_APP_KEY=flexiqueue-prod-key
REVERB_APP_SECRET=flexiqueue-prod-secret
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=6001
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
# Empty = Vite chooses: dev direct :6001, prod same-origin proxy. For Laragon HTTPS + Apache, set true (see doc above).
VITE_REVERB_VIA_PROXY=

# Pusher (when BROADCAST_CONNECTION=pusher, e.g. hosting). Create app at pusher.com.
# Build hosting tarball with: VITE_BROADCASTER=pusher and .env.hosting.
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
VITE_BROADCASTER=reverb
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Server-side TTS (optional). When not set, display uses browser speechSynthesis.
TTS_DRIVER=elevenlabs
TTS_DEFAULT_VOICE_ID=ofwR5KwL2nT4XZAub5qx
ELEVENLABS_API_KEY=sk_388104f6e46394f707764a8388b8a48f8d76e4d2c104ac9e
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
