# Central profile (Pusher realtime)
# Copy to .env.hosting or .env as appropriate for central deployment target.

APP_NAME=FlexiQueue
APP_ENV=production
APP_MODE=central
APP_KEY=
APP_DEBUG=false
APP_URL=https://flexiqueue.click

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
VITE_BROADCASTER=pusher
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
